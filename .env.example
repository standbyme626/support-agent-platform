# Environment selector: dev | prod
SUPPORT_AGENT_ENV=dev

# Optional: override default SQLite path from config file
SUPPORT_AGENT_SQLITE_PATH=

# LLM runtime (business layer; OpenClaw is ingress/session/routing only)
LLM_ENABLED=true
LLM_PROVIDER=openai_compatible
OPENAI_BASE_URL=http://100.90.236.32:11434/v1
OPENAI_API_KEY=ollama-local
OPENAI_MODEL=qwen3.5:9b
LLM_TIMEOUT_SECONDS=60
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=64
LLM_STREAM=false

# WeCom channel credentials
WECOM_BOT_ID=aibLIwMldZzme6wuhsgwhCAXO6ec9bT8cks
WECOM_BOT_SECRET=zexKZa4RhtrIbnTzT1LCfmGSRjGe2zCLNRx4SduoAyx

# WeCom -> workflow bridge (OpenClaw forwards ingress to this endpoint)
WECOM_BRIDGE_HOST=127.0.0.1
WECOM_BRIDGE_PORT=18081
WECOM_BRIDGE_PATH=/wecom/process
WECOM_BRIDGE_URL=http://127.0.0.1:18081/wecom/process

# Secrets are read in priority: ENV -> *_FILE path -> /run/secrets/<name>
OPENCLAW_WEBHOOK_SECRET=
OPENCLAW_WEBHOOK_SECRET_FILE=
FEISHU_APP_SECRET=
FEISHU_APP_SECRET_FILE=
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_TOKEN_FILE=
WECOM_AGENT_SECRET=zexKZa4RhtrIbnTzT1LCfmGSRjGe2zCLNRx4SduoAyx
WECOM_AGENT_SECRET_FILE=
